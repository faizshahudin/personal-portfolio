---
export interface Props {
  title: string;
  slug: string;
  date: string;
  description: string;
  tags?: string[];
  readingTime?: string;
}

const { title, slug, date, description, tags = [], readingTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-MY', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="post-card__link">
    <div class="post-card__meta">
      <time class="post-card__date">{formattedDate}</time>
      {readingTime && <span class="post-card__sep">·</span>}
      {readingTime && <span class="post-card__read">{readingTime}</span>}
    </div>

    <h2 class="post-card__title">{title}</h2>
    <p class="post-card__desc">{description}</p>

    {tags.length > 0 && (
      <div class="post-card__tags">
        {tags.map(tag => (
          <span class={`tag ${tag === 'Architecture' || tag === 'System Design' ? 'tag--amber' : 'tag--ghost'}`}>
            {tag}
          </span>
        ))}
      </div>
    )}

    <span class="post-card__cta">Read article →</span>
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-2);
    transition: border-color .25s, transform .25s, box-shadow .25s;
    overflow: hidden;
  }
  .post-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  .post-card__link {
    display: block;
    padding: 28px 32px;
    text-decoration: none;
    color: inherit;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .post-card__date,
  .post-card__read {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .post-card__sep { color: var(--text-3); font-size: 12px; }

  .post-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
    transition: color .2s;
  }
  .post-card:hover .post-card__title { color: var(--amber); }

  .post-card__desc {
    color: var(--text-2);
    font-size: 14px;
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .post-card__cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--amber);
    letter-spacing: 0.03em;
    transition: gap .2s;
  }
</style>
